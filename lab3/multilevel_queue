#include <stdio.h>

struct process{
    int id;
    int at,bt;
    int ct,wt,tat;
    int type; 
    int rt;
};

int main(){

    int n;
    printf("Enter number of processes: ");
    scanf("%d",&n);

    struct process p[n];

    for(int i=0;i<n;i++){

        printf("\nProcess %d\n",i);

        p[i].id=i;

        printf("Enter arrival time: ");
        scanf("%d",&p[i].at);

        printf("Enter burst time: ");
        scanf("%d",&p[i].bt);

        printf("Enter type (0 = System, 1 = User): ");
        scanf("%d",&p[i].type);

        p[i].rt=p[i].bt;
    }

    int completed=0,time=0;

    while(completed<n){

        int idx=-1;

        for(int i=0;i<n;i++){
            if(p[i].at<=time && p[i].rt>0 && p[i].type==0){
                if(idx==-1 || p[i].at<p[idx].at)
                    idx=i;
            }
        }

        if(idx==-1){
            for(int i=0;i<n;i++){
                if(p[i].at<=time && p[i].rt>0 && p[i].type==1){
                    if(idx==-1 || p[i].at<p[idx].at)
                        idx=i;
                }
            }
        }

        if(idx==-1){
            time++;
            continue;
        }

        p[idx].rt--;
        time++;

        if(p[idx].rt==0){

            p[idx].ct=time;
            p[idx].tat=p[idx].ct-p[idx].at;
            p[idx].wt=p[idx].tat-p[idx].bt;

            completed++;
        }
    }

    float avgwt=0,avgtat=0;

    printf("\nID\tType\tAT\tBT\tCT\tWT\tTAT\n");

    for(int i=0;i<n;i++){

        if(p[i].type==0)
            printf("%d\tSystem\t%d\t%d\t%d\t%d\t%d\n",p[i].id,p[i].at,p[i].bt,p[i].ct,p[i].wt,p[i].tat);
        else
            printf("%d\tUser\t%d\t%d\t%d\t%d\t%d\n",p[i].id,p[i].at,p[i].bt,p[i].ct,p[i].wt,p[i].tat);

        avgwt+=p[i].wt;
        avgtat+=p[i].tat;
    }

    printf("\nAverage Waiting Time: %.2f",avgwt/n);
    printf("\nAverage Turnaround Time: %.2f\n",avgtat/n);

    return 0;
}
