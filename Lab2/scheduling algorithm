#include <stdio.h>

int main() {
    int n, i, choice, time = 0, completed = 0;
    int at[20], bt[20], pr[20], rt[20], ct[20], tat[20], wt[20], done[20] = {0};
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Enter AT, BT and Priority for P%d: ", i + 1);
        scanf("%d%d%d", &at[i], &bt[i], &pr[i]);
        rt[i] = bt[i];
    }

    printf("\n1. Preemptive Priority");
    printf("\n2. Non-Preemptive Priority");
    printf("\nEnter choice: ");
    scanf("%d", &choice);

    while(completed < n) {
        int idx = -1, hp = 9999;

        for(i = 0; i < n; i++) {
            if(at[i] <= time && !done[i] && pr[i] < hp) {
                hp = pr[i];
                idx = i;
            }
        }

        if(idx == -1) {
            time++;
            continue;
        }

        if(choice == 1) {      // Preemptive
            rt[idx]--;
            time++;

            if(rt[idx] == 0) {
                done[idx] = 1;
                completed++;
                ct[idx] = time;
            }
        }
        else {                 // Non-Preemptive
            time += bt[idx];
            done[idx] = 1;
            completed++;
            ct[idx] = time;
        }
    }

    printf("\nP\tAT\tBT\tPR\tCT\tWT\tTAT\n");

    for(i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];

        avg_wt += wt[i];
        avg_tat += tat[i];

        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               i+1, at[i], bt[i], pr[i],
               ct[i], wt[i], tat[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt/n);
    printf("\nAverage Turnaround Time = %.2f", avg_tat/n);

    return 0;
}

